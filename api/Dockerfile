# Используем последнюю актуальную версию Node.js на Alpine
FROM node:26-alpine

# Создаем папку приложения в контейнере
WORKDIR /app

# Копируем файлы со списком зависимостей
COPY package*.json ./

# Устанавливаем зависимости
RUN npm install

# Копируем весь код приложения
COPY . .

# Открываем порт для приложения
EXPOSE 3000

# Запускаем приложение через nodemon для локальной разработки
CMD ["npm", "run", "dev"]
